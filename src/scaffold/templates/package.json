{
	"name": "{{PROJECT_NAME}}",
	"description": "A Kirby CMS project created with ProjectWizard",
	"scripts": {
		"tailwindWatch": "npx @tailwindcss/cli -i ./storage/temp/tailwind.css -o ./public/assets/css/site.min.css --watch --minify",
		"tailwindBuild": "npx @tailwindcss/cli -i ./storage/temp/tailwind.css -o ./public/assets/css/site.min.css --minify",
		"panelWatch": "npx @tailwindcss/cli -i ./site/config/panel.css -o ./public/assets/css/panel.min.css --watch --minify",
		"kirbyupSynced": "node kirbyup-sync.config.js",
		"concatenateJS": "node build-js.config.js",
		"buildModules": "for f in site/plugins/*/src/js/modules/*.js; do [ -f \"$f\" ] && npx terser \"$f\" -c -m -o \"public/assets/js/$(basename \"${f%.js}\").min.js\"; done || true",
		"dev": "npm-run-all --parallel tailwindWatch panelWatch kirbyupSynced",
		"build": "npm-run-all tailwindBuild concatenateJS buildModules"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.1.13",
		"kirbyup": "^3.4.1",
		"npm-run-all": "^4.1.5",
		"tailwindcss": "^4.1.13",
		"tailwindcss-debug-screens": "^3.0.1",
		"terser": "^5.44.0"
	},
	"dependencies": {
		"marked": "^16.4.1"
	}
}
